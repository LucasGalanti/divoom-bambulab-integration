# Copy this file to .env and fill in your values
# Never commit .env to version control

# Divoom Pixoo 64 — fixed IP (set DHCP reservation on your router)
PIXOO_IP=192.168.1.XXX

# BambuLab X1C — serial number (Settings → Device → Serial on the printer screen)
BAMBU_SERIAL=BBLP00CXXXXXXX

# ---------------------------------------------------------------------------
# Connection mode: choose ONE
# ---------------------------------------------------------------------------

# --- Option A: Cloud mode (RECOMMENDED) ------------------------------------
# Printer keeps full Bambu Handy + Bambu Cloud functionality.
# No LAN mode needed. ~500ms update latency.
BAMBU_CONNECTION_MODE=cloud
BAMBU_EMAIL=your@email.com
BAMBU_PASSWORD=yourpassword

# --- Option B: LAN mode ----------------------------------------------------
# Printer must have LAN mode enabled (disables Bambu Handy / cloud).
# ~100ms update latency.
# BAMBU_CONNECTION_MODE=lan
# BAMBU_PRINTER_IP=192.168.1.XXX
# BAMBU_ACCESS_CODE=XXXXXXXX
# (LAN access code: Settings → Network → LAN Mode on the printer display)

# Optional: display brightness 0-100
PIXOO_BRIGHTNESS=80

# Optional: minimum seconds between display updates (avoid overloading the Pixoo)
PIXOO_UPDATE_INTERVAL=3
